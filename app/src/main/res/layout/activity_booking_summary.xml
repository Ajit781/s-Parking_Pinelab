<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/parking"
    tools:context=".BookingSummaryActivity">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black_overlay"
        android:alpha="0.8"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/dp_10"
                android:orientation="vertical">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_15"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_50"
                        android:layout_margin="@dimen/dp_5"
                        android:background="@drawable/border"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_fromDate"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1.6"
                            android:gravity="center"
                            android:hint="From Date"
                            android:paddingLeft="@dimen/dp_5"
                            android:textColor="@color/black"
                            android:textSize="@dimen/sp_16"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btn_calenderfrom"
                            android:layout_width="@dimen/dp_30"
                            android:layout_height="@dimen/dp_30"
                            android:layout_gravity="end|center"
                            android:layout_margin="@dimen/dp_10"
                            android:background="@drawable/calendar" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_50"
                        android:layout_margin="@dimen/dp_5"
                        android:background="@drawable/border"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_toDate"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1.6"
                            android:gravity="center"
                            android:hint="To Date"
                            android:paddingLeft="@dimen/dp_5"
                            android:textColor="@color/black"
                            android:textSize="@dimen/sp_16"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btn_calenderto"
                            android:layout_width="@dimen/dp_30"
                            android:layout_height="@dimen/dp_30"
                            android:layout_gravity="end|center"
                            android:layout_margin="@dimen/dp_10"
                            android:background="@drawable/calendar" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_50"
                    android:layout_marginLeft="@dimen/dp_5"
                    android:layout_marginTop="@dimen/dp_10"
                    android:layout_marginRight="@dimen/dp_5"
                    android:background="@drawable/buttonborder"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_Submit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:background="@null"
                        android:text="@string/submit"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_16" />
                </LinearLayout>

                <RelativeLayout
                    android:id="@+id/rl_recycler_main"
                    android:layout_width="fill_parent"
                    android:layout_height="@dimen/dp_280"
                    android:layout_marginTop="@dimen/dp_20"
                    android:background="@color/white"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/ll_main"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_30"
                        android:layout_gravity="center"
                        android:layout_marginTop="@dimen/dp_15"
                        android:background="@color/white"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:background="@color/white"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_weight="1"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/tv_sl_no"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="0.5"
                                    android:gravity="center"
                                    android:singleLine="true"
                                    android:text="V/C"
                                    android:textColor="@color/black"
                                    android:textSize="@dimen/sp_16"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tv_vehicle_type"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:singleLine="true"
                                    android:text="VEHICLE NAME"
                                    android:textColor="@color/black"
                                    android:textSize="@dimen/sp_16"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tv_count"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="0.8"
                                    android:gravity="center"
                                    android:text="COUNT"
                                    android:textColor="@color/black"
                                    android:textSize="@dimen/sp_16"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tv_amount"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:singleLine="true"
                                    android:text="AMOUNT"
                                    android:textColor="@color/black"
                                    android:textSize="@dimen/sp_16"
                                    android:textStyle="bold" />

                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_below="@id/ll_main"
                        android:orientation="vertical">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_parking_list"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/_3sdp"
                            android:layout_marginTop="@dimen/_3sdp"
                            android:layout_marginRight="@dimen/_3sdp"
                            android:scrollbars="vertical" />

                        <RelativeLayout
                            android:id="@+id/no_result"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:visibility="gone">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_centerInParent="true"
                                android:gravity="center"
                                android:orientation="vertical">

                                <ImageView
                                    android:id="@+id/noitem_in_cart"
                                    android:layout_width="@dimen/dp_200"
                                    android:layout_height="@dimen/dp_200"
                                    android:background="@android:color/transparent"
                                    android:padding="@dimen/dp_60"
                                    android:scaleType="centerInside" />

                                <TextView
                                    android:id="@+id/tv_message"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:layout_marginTop="@dimen/dp_10"
                                    android:gravity="center"
                                    android:singleLine="false"
                                    android:text="@string/no_item"
                                    android:textColor="@color/white"
                                    android:textSize="@dimen/sp_24" />
                            </LinearLayout>
                        </RelativeLayout>

                    </LinearLayout>


                </RelativeLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dp_50"
                    android:layout_gravity="right"
                    android:layout_marginLeft="@dimen/dp_5"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="40dp"
                    android:layout_marginRight="@dimen/dp_5"
                    android:background="@drawable/buttonborder"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_print"
                        android:layout_width="@dimen/dp_200"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"

                        android:background="@null"
                        android:text="@string/print"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_16"
                        android:visibility="gone" />
                </LinearLayout>


            </LinearLayout>
        </ScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>