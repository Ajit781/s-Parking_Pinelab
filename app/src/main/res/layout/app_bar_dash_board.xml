<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/content_dashoard"
    android:background="@drawable/parking"
    tools:context="com.innovus.vyoma.s_parking_agentApollo.DashBoardActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/AppTheme.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:popupTheme="@style/AppTheme.PopupOverlay">
            <LinearLayout
                android:id="@+id/ll_vehicle_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@android:color/transparent">
                <ImageView
                    android:id="@+id/iv_fourWheeler"
                    android:layout_width="@dimen/dp_20"
                    android:layout_height="@dimen/dp_20"
                    android:layout_marginLeft="@dimen/dp_15"
                    android:src="@drawable/parking_boom"/>
                <TextView
                    android:id="@+id/tv_four_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/dp_5"
                    android:textColor="@color/white"/>
                <ImageView
                    android:id="@+id/iv_twoWheeler"
                    android:layout_width="@dimen/dp_20"
                    android:layout_height="@dimen/dp_20"
                    android:visibility="gone"
                    android:layout_marginLeft="@dimen/dp_20"
                    android:src="@drawable/bikewhite"/>
                <TextView
                    android:id="@+id/tv_two_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/dp_5"
                    android:visibility="gone"
                    android:textColor="@color/white"/>

            </LinearLayout>

            <ImageView
                android:id="@+id/iv_printer"
                android:layout_width="@dimen/dp_20"
                android:layout_height="@dimen/dp_20"
                android:visibility="gone"
                android:layout_marginLeft="@dimen/dp_20"
                android:src="@drawable/printer_"/>

        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <include layout="@layout/content_dash_board" />


    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_parkingstart"
        android:layout_width="86dp"
        android:layout_height="96dp"
        app:fabCustomSize="@dimen/dp_86"
        android:layout_gravity="bottom|end"
        android:background="#3C9710"
        app:backgroundTint="#3C9710"
        android:tooltipText="@string/StartParking"
        android:layout_margin="@dimen/fab_margin"
        app:elevation="0dp"
        app:fabSize="normal"
        app:maxImageSize="40dp"
        android:scaleType="fitCenter"
        android:src="@drawable/start" />


    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_parkingend"
        android:layout_width="86dp"
        android:layout_height="96dp"
        android:layout_gravity="bottom|left"
        android:background="@color/colorPrimary"
        android:layout_marginBottom="0dp"
        android:layout_marginEnd="0dp"
        android:layout_marginLeft="0dp"
        android:layout_marginRight="0dp"
        android:layout_marginStart="0dp"
        android:layout_marginTop="0dp"
        app:fabCustomSize="@dimen/dp_86"
        app:maxImageSize="40dp"
        android:scaleType="fitCenter"
        android:tooltipText="@string/EndParking"
        android:src="@drawable/stop"
        android:layout_margin="@dimen/fab_margin"
        app:layout_anchorGravity="top" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_parking_gate_open"
        android:layout_width="86dp"
        android:layout_height="96dp"
        android:layout_gravity="bottom|center"
        android:background="@color/colorPrimary"
        android:layout_marginBottom="0dp"
        android:layout_marginEnd="0dp"
        android:layout_marginLeft="0dp"
        android:layout_marginRight="0dp"
        android:layout_marginStart="0dp"
        android:layout_marginTop="0dp"
        android:tooltipText="@string/EndParking"
        android:src="@drawable/access"
        android:layout_margin="@dimen/fab_margin"
        app:fabCustomSize="@dimen/dp_86"
        app:maxImageSize="40dp"
        android:visibility="gone"
        app:layout_anchorGravity="top" />


</androidx.coordinatorlayout.widget.CoordinatorLayout>
